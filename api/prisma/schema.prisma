// ResumeVerify X™ — Complete Prisma Schema
// Phase 2: Database Architecture

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  CANDIDATE
  TEACHER
  MENTOR
  RECRUITER
  PLACEMENT_OFFICER
  UNIVERSITY_ADMIN
  COMPANY_ADMIN
  SUPER_ADMIN
}

enum TrustLevel {
  HIGH_RISK    // <40
  MODERATE     // 60-79
  VERIFIED     // 80-94
  HIGHLY_TRUSTED // 95+
}

enum Department {
  CSE
  IT
  AI_DS
  MECHANICAL
  CIVIL
  ECE
  EEE
  MBA
  COMMERCE
  MEDICAL
  LAW
  DESIGN
  PHARMACY
  AGRICULTURE
}

enum PipelineStage {
  APPLIED
  SCREENING
  ASSESSMENT
  HR_ROUND
  TECHNICAL_ROUND
  FINAL_ROUND
  OFFER
  HIRED
  REJECTED
}

enum AssignmentType {
  QUIZ
  CODING
  SQL
  APTITUDE
  MCQ
  DEBUGGING
  SUBJECTIVE
}

enum InterviewType {
  CODING
  HR
  COMMUNICATION
  SYSTEM_DESIGN
  TECHNICAL
  PANEL
}

enum NotificationType {
  ASSIGNMENT_ALERT
  INTERVIEW_REMINDER
  RECRUITER_INVITE
  AI_REMINDER
  PLACEMENT_ALERT
  TRUST_SCORE_CHANGE
  CONTEST_ALERT
  SYSTEM
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  VOICE
  CODE
  SYSTEM
}

enum SubscriptionPlan {
  FREE_STUDENT
  PREMIUM_STUDENT
  UNIVERSITY_WORKSPACE
  PLACEMENT_SUITE
  HR_PREMIUM
  ENTERPRISE_HIRING
  AI_INTERVIEW_CREDITS
}

enum FraudRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─────────────────────────────────────────────
// USERS & AUTHENTICATION
// ─────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String
  phone             String?
  bio               String?
  avatarUrl         String?
  role              Role
  isVerified        Boolean   @default(false)
  isActive          Boolean   @default(true)
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  onboardingDone    Boolean   @default(false)
  subscriptionPlan  SubscriptionPlan @default(FREE_STUDENT)
  
  // External Connections
  githubUsername    String?
  githubToken       String?
  leetcodeUsername  String?
  linkedinUrl       String?
  codechefUsername  String?
  hackerrankUsername String?
  
  // Custom unstructured profile data
  skills            Json?     @default("[]")
  experience        Json?     @default("[]")
  certifications    Json?     @default("[]")
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  university        University?     @relation(fields: [universityId], references: [id])
  universityId      String?
  department        Department?
  
  sessions          Session[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  sentMessages      Message[]       @relation("SentMessages")
  receivedMessages  Message[]       @relation("ReceivedMessages")
  
  // Candidate specific
  resume            Resume?
  trustScore        TrustScore?
  fraudAnalysis     FraudAnalysis?
  projects          Project[]
  codingSubmissions CodingSubmission[]
  careerGrowth      CareerGrowth?
  financialAnalytics FinancialAnalytic[]
  rankings          Ranking[]
  jobApplications   JobApplication[]
  networkConnections NetworkingConnection[] @relation("UserConnections")
  networkConnectionsOf NetworkingConnection[] @relation("UserConnectionsOf")
  
  // Teacher specific
  createdAssignments Assignment[]    @relation("TeacherAssignments")
  createdGroups      Group[]         @relation("CreatedGroups")
  
  // Recruiter specific
  recruiterNotes    RecruiterNote[]
  candidatePipelines CandidatePipeline[] @relation("RecruiterPipeline")
  
  // Interview
  interviewsAsCandidate InterviewParticipant[] @relation("CandidateInterviews")
  interviewsAsInterviewer InterviewParticipant[] @relation("InterviewerInterviews")
  
  // Groups
  groupMemberships  GroupMember[]
  
  // AI Reports
  aiReports         AIReport[]
  
  @@index([email])
  @@index([role])
  @@index([universityId])
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique
  deviceInfo  String?
  ipAddress   String?
  userAgent   String?
  isActive    Boolean  @default(true)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([token])
}

// ─────────────────────────────────────────────
// UNIVERSITY & WORKSPACE
// ─────────────────────────────────────────────

model University {
  id              String    @id @default(cuid())
  name            String
  code            String    @unique
  logoUrl         String?
  website         String?
  location        String?
  isApproved      Boolean   @default(false)
  isActive        Boolean   @default(true)
  subscriptionPlan SubscriptionPlan @default(FREE_STUDENT)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  users           User[]
  announcements   Announcement[]
  groups          Group[]
  placementDrives PlacementDrive[]
  
  @@index([code])
}

// ─────────────────────────────────────────────
// TRUST & IDENTITY
// ─────────────────────────────────────────────

model TrustScore {
  id                    String      @id @default(cuid())
  userId                String      @unique
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  totalScore            Float       @default(0)
  trustLevel            TrustLevel  @default(HIGH_RISK)
  
  // Component scores (0-100 each)
  resumeQualityScore    Float       @default(0)
  githubScore           Float       @default(0)
  leetcodeScore         Float       @default(0)
  projectScore          Float       @default(0)
  codingPerformance     Float       @default(0)
  interviewPerformance  Float       @default(0)
  communicationScore    Float       @default(0)
  assignmentCompletion  Float       @default(0)
  learningConsistency   Float       @default(0)
  fraudPenalty          Float       @default(0)
  
  // AI Analysis
  aiExplanation         String?
  weakAreas             String[]
  improvementSuggestions String[]
  
  weeklyGrowth          Float       @default(0)
  lastCalculated        DateTime    @default(now())
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  history               TrustScoreHistory[]
  
  @@index([userId])
  @@index([totalScore])
}

model TrustScoreHistory {
  id           String     @id @default(cuid())
  trustScoreId String
  trustScore   TrustScore @relation(fields: [trustScoreId], references: [id], onDelete: Cascade)
  score        Float
  reason       String?
  createdAt    DateTime   @default(now())
  
  @@index([trustScoreId])
}

model FraudAnalysis {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  fraudProbability    Float     @default(0)
  riskLevel           FraudRisk @default(LOW)
  integrityScore      Float     @default(100)
  
  // Flags
  fakeResume          Boolean   @default(false)
  copiedProjects      Boolean   @default(false)
  aiGeneratedContent  Boolean   @default(false)
  fakeGithubActivity  Boolean   @default(false)
  fakeCertificates    Boolean   @default(false)
  suspiciousCoding    Boolean   @default(false)
  impossibleTimelines Boolean   @default(false)
  
  evidence            String[]
  warnings            String[]
  aiAnalysis          String?
  
  lastAnalyzed        DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  @@index([userId])
  @@index([riskLevel])
}

// ─────────────────────────────────────────────
// RESUME
// ─────────────────────────────────────────────

model Resume {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  fileUrl             String?
  parsedText          String?
  
  // AI Analysis
  overallScore        Float    @default(0)
  structureScore      Float    @default(0)
  skillRelevanceScore Float    @default(0)
  projectQualityScore Float    @default(0)
  keywordScore        Float    @default(0)
  experienceScore     Float    @default(0)
  
  weakAreas           String[]
  heatmapData         Json?
  aiFeedback          String?
  improvementTips     String[]
  
  isAnalyzed          Boolean  @default(false)
  lastAnalyzed        DateTime?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@index([userId])
}

// ─────────────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────────────

model Project {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title               String
  description         String?
  githubUrl           String?
  liveUrl             String?
  techStack           String[]
  
  // Verification
  originalityScore    Float    @default(0)
  deploymentVerified  Boolean  @default(false)
  githubValidated     Boolean  @default(false)
  documentationScore  Float    @default(0)
  
  isVerifiedAI        Boolean  @default(false)
  isVerifiedDeployment Boolean @default(false)
  isVerifiedTeam      Boolean  @default(false)
  
  skillProofUrl       String?
  aiAnalysis          String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@index([userId])
}

// ─────────────────────────────────────────────
// ASSIGNMENTS & SUBMISSIONS
// ─────────────────────────────────────────────

model Assignment {
  id              String         @id @default(cuid())
  teacherId       String
  teacher         User           @relation("TeacherAssignments", fields: [teacherId], references: [id])
  groupId         String?
  group           Group?         @relation(fields: [groupId], references: [id])
  
  title           String
  description     String?
  type            AssignmentType
  difficulty      String         @default("MEDIUM") // EASY, MEDIUM, HARD
  topic           String?
  subject         String?
  totalMarks      Int            @default(100)
  
  questions       Json?
  testCases       Json?
  
  dueDate         DateTime?
  isPublished     Boolean        @default(false)
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  submissions     CodingSubmission[]
  
  @@index([teacherId])
  @@index([groupId])
}

model CodingSubmission {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignmentId    String?
  assignment      Assignment? @relation(fields: [assignmentId], references: [id])
  
  problemSlug     String?
  language        String
  code            String
  
  status          String   @default("PENDING") // PENDING, ACCEPTED, WRONG, TLE, MLE, RE
  executionTime   Float?
  memoryUsed      Float?
  score           Float    @default(0)
  
  testCasesPassed Int      @default(0)
  totalTestCases  Int      @default(0)
  executionLogs   String?
  
  plagiarismScore Float    @default(0)
  isFlagged       Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  
  @@index([userId])
  @@index([assignmentId])
}

// ─────────────────────────────────────────────
// GROUPS
// ─────────────────────────────────────────────

model Group {
  id            String      @id @default(cuid())
  name          String
  description   String?
  coverImage    String?
  createdById   String
  createdBy     User        @relation("CreatedGroups", fields: [createdById], references: [id])
  universityId  String?
  university    University? @relation(fields: [universityId], references: [id])
  
  isActive      Boolean     @default(true)
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  members       GroupMember[]
  assignments   Assignment[]
  announcements Announcement[]
  messages      Message[]
  
  @@index([createdById])
  @@index([universityId])
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER") // MEMBER, ADMIN, TEACHER, MENTOR
  joinedAt  DateTime @default(now())
  
  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model Announcement {
  id           String      @id @default(cuid())
  title        String
  content      String
  authorId     String
  groupId      String?
  group        Group?      @relation(fields: [groupId], references: [id])
  universityId String?
  university   University? @relation(fields: [universityId], references: [id])
  isPinned     Boolean     @default(false)
  createdAt    DateTime    @default(now())
  
  @@index([groupId])
}

// ─────────────────────────────────────────────
// INTERVIEW ROOMS
// ─────────────────────────────────────────────

model InterviewRoom {
  id              String        @id @default(cuid())
  title           String
  type            InterviewType
  
  scheduledAt     DateTime?
  startedAt       DateTime?
  endedAt         DateTime?
  
  isLive          Boolean       @default(false)
  roomCode        String        @unique @default(cuid())
  
  // Config
  hasVideo        Boolean       @default(true)
  hasWhiteboard   Boolean       @default(false)
  hasCodeEditor   Boolean       @default(true)
  recordingEnabled Boolean      @default(false)
  
  integrityScore  Float?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  participants    InterviewParticipant[]
  recordings      InterviewRecording[]
  scorecards      InterviewScorecard[]
  
  @@index([roomCode])
}

model InterviewParticipant {
  id              String        @id @default(cuid())
  roomId          String
  room            InterviewRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  candidateId     String?
  candidate       User?         @relation("CandidateInterviews", fields: [candidateId], references: [id])
  interviewerId   String?
  interviewer     User?         @relation("InterviewerInterviews", fields: [interviewerId], references: [id])
  panelRole       String?       // HR, TECH_LEAD, MANAGER, OBSERVER
  
  joinedAt        DateTime?
  leftAt          DateTime?
  
  // Cheating detection
  tabSwitches     Int           @default(0)
  focusLossCount  Int           @default(0)
  copyPasteCount  Int           @default(0)
  suspiciousEvents Json?
  
  @@index([roomId])
}

model InterviewRecording {
  id          String        @id @default(cuid())
  roomId      String
  room        InterviewRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  videoUrl    String?
  audioUrl    String?
  transcript  String?
  duration    Int?          // seconds
  
  createdAt   DateTime      @default(now())
  
  @@index([roomId])
}

model InterviewScorecard {
  id              String        @id @default(cuid())
  roomId          String
  room            InterviewRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  technicalScore  Float         @default(0)
  communicationScore Float      @default(0)
  problemSolving  Float         @default(0)
  cultureFit      Float         @default(0)
  overallScore    Float         @default(0)
  
  notes           String?
  recommendation  String?       // HIRE, REJECT, MAYBE
  
  createdAt       DateTime      @default(now())
  
  @@index([roomId])
}

// ─────────────────────────────────────────────
// JOBS & PIPELINE
// ─────────────────────────────────────────────

model Job {
  id              String   @id @default(cuid())
  title           String
  company         String
  location        String?
  type            String   @default("FULL_TIME") // FULL_TIME, PART_TIME, INTERNSHIP, CONTRACT
  description     String?
  requirements    String[]
  techStack       String[]
  salaryMin       Float?
  salaryMax       Float?
  
  minCGPA         Float?
  minTrustScore   Float?
  
  postedById      String?
  isActive        Boolean  @default(true)
  deadline        DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  applications    JobApplication[]
  
  @@index([company])
  @@index([isActive])
}

model JobApplication {
  id          String        @id @default(cuid())
  jobId       String
  job         Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  stage       PipelineStage @default(APPLIED)
  coverLetter String?
  
  appliedAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  pipelines   CandidatePipeline[]
  
  @@unique([jobId, userId])
  @@index([userId])
  @@index([jobId])
}

model CandidatePipeline {
  id              String        @id @default(cuid())
  applicationId   String
  application     JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  recruiterId     String
  recruiter       User          @relation("RecruiterPipeline", fields: [recruiterId], references: [id])
  
  stage           PipelineStage @default(SCREENING)
  notes           String?
  movedAt         DateTime      @default(now())
  
  @@index([applicationId])
  @@index([recruiterId])
}

model RecruiterNote {
  id          String   @id @default(cuid())
  recruiterId String
  recruiter   User     @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  candidateId String
  note        String
  createdAt   DateTime @default(now())
  
  @@index([recruiterId])
  @@index([candidateId])
}

// ─────────────────────────────────────────────
// PLACEMENT DRIVES
// ─────────────────────────────────────────────

model PlacementDrive {
  id              String      @id @default(cuid())
  company         String
  universityId    String?
  university      University? @relation(fields: [universityId], references: [id])
  
  description     String?
  eligibilityCriteria Json?
  
  driveDate       DateTime?
  applicationDeadline DateTime?
  isActive        Boolean     @default(true)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([universityId])
}

// ─────────────────────────────────────────────
// RANKINGS
// ─────────────────────────────────────────────

model Ranking {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  universityRank Int?
  departmentRank Int?
  codingRank    Int?
  placementRank Int?
  
  xp            Int      @default(0)
  badges        String[]
  achievements  String[]
  streakDays    Int      @default(0)
  
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
}

// ─────────────────────────────────────────────
// CAREER & FINANCIAL ANALYTICS
// ─────────────────────────────────────────────

model CareerGrowth {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  targetRole          String?
  targetCompany       String?
  targetSalary        Float?
  placementProbability Float   @default(0)
  careerHealthScore   Float    @default(0)
  
  aiRoadmap           Json?
  weeklyPlan          Json?
  weakSkills          String[]
  
  updatedAt           DateTime @updatedAt
  
  @@index([userId])
}

model FinancialAnalytic {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  category        String   // INTERNSHIP, FREELANCE, HACKATHON, CERT_INVESTMENT, LEARNING
  amount          Float
  description     String?
  date            DateTime @default(now())
  
  @@index([userId])
}

// ─────────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────────

model Message {
  id          String      @id @default(cuid())
  senderId    String
  sender      User        @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String?
  receiver    User?       @relation("ReceivedMessages", fields: [receiverId], references: [id])
  groupId     String?
  group       Group?      @relation(fields: [groupId], references: [id])
  
  content     String
  type        MessageType @default(TEXT)
  fileUrl     String?
  
  isPinned    Boolean     @default(false)
  isRead      Boolean     @default(false)
  
  createdAt   DateTime    @default(now())
  
  @@index([senderId])
  @@index([receiverId])
  @@index([groupId])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  priority  String           @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  
  createdAt DateTime         @default(now())
  
  @@index([userId])
  @@index([isRead])
}

// ─────────────────────────────────────────────
// NETWORKING
// ─────────────────────────────────────────────

model NetworkingConnection {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserConnections", fields: [userId], references: [id], onDelete: Cascade)
  connectedId String
  connected   User     @relation("UserConnectionsOf", fields: [connectedId], references: [id], onDelete: Cascade)
  
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  
  createdAt   DateTime @default(now())
  
  @@unique([userId, connectedId])
  @@index([userId])
}

model Community {
  id          String   @id @default(cuid())
  name        String
  description String?
  coverImage  String?
  category    String?
  memberCount Int      @default(0)
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  @@index([category])
}

// ─────────────────────────────────────────────
// AI REPORTS
// ─────────────────────────────────────────────

model AIReport {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  reportType  String   // CAREER_PLAN, RESUME_ANALYSIS, FRAUD_REPORT, SKILL_REPORT, INTERVIEW_ANALYSIS
  prompt      String?
  response    Json
  tokensUsed  Int      @default(0)
  model       String   @default("gpt-4")
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([reportType])
}

// ─────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// QUESTION BANK
// ─────────────────────────────────────────────

model Question {
  id          String         @id @default(cuid())
  topic       String
  subject     String?
  difficulty  String         @default("MEDIUM")
  type        AssignmentType
  question    String
  options     String[]
  answer      String?
  explanation String?
  marks       Int            @default(1)
  tags        String[]
  
  createdById String?
  isPublic    Boolean        @default(false)
  
  createdAt   DateTime       @default(now())
  
  @@index([topic])
  @@index([difficulty])
  @@index([type])
}
