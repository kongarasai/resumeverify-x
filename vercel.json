{
  "version": 2,
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://resumeverify-api.onrender.com/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/web/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://resumeverify-api.onrender.com",
    "NEXT_PUBLIC_WS_URL": "wss://resumeverify-api.onrender.com"
  }
}
